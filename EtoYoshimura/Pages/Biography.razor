@page "/Takatsuki"

<PageTitle>Takatsuki Sen</PageTitle>
<div class="biography-page">
    <h1><b>Ditzy Author</b></h1>
    <div class="biography-layout-container">
        <div class="bio-box">
            <p>
                Takatsuki Sen is a best-selling horror novelist, finding success ever since submitting her
                500-page manuscript of <i>Dear Kafka</i> to Shoeisha in her teenage years. This was what
                launched her career with 500,000 copies sold and establising her reputation as a promising
                up-and-coming author in the scene.
            </p>
            <img class="box-image" src="https://static.wikia.nocookie.net/tokyoghoul/images/4/45/Younger_Eto.png/revision/latest?cb=20160522224457" 
                 alt="Teenage Takatsuki"/>
            <br/>
            <i>Takatsuki before her debut</i>
        </div>
    <div class="sidebar-container">
        <div class="image-container">
            <img src="https://external-content.duckduckgo.com/iu/?u=http%3A%2F%2Fvignette2.wikia.nocookie.net%2Ftokyoghoul%2Fimages%2F2%2F2e%2FEto_makes_her_debut_as_Sen_Takatsuki.png%2Frevision%2Flatest%3Fcb%3D20161203055451&f=1&nofb=1&ipt=319802a16e6be39c9ce0d52994e1e78553b231c90e3689f261bc224d0d360dd7"
                 alt="Takatsuki Sen"/>
        </div>
        <div class="profile-details-box">
            Full Name:  Takatsuki Sen <br/>
            Gender:     Female <br/>
            Species:    <i>Human</i> <br/>
            Age:        Mid-20s <br/>
            Profession: Author
        </div>
        <div class="link-buttons">
